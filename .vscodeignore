.claude/**
The Gif and Images/**
src/**
test/**
node_modules/**
# Re-include ONLY the playwright-core runtime files (NOT bin/ — its browser-installer
# shell scripts trip the Marketplace malware scanner, and PocketView reuses the
# system Chrome/Edge so it never runs them).
!node_modules/playwright-core/package.json
!node_modules/playwright-core/index.js
!node_modules/playwright-core/index.mjs
!node_modules/playwright-core/index.d.ts
!node_modules/playwright-core/cli.js
!node_modules/playwright-core/browsers.json
!node_modules/playwright-core/LICENSE
!node_modules/playwright-core/NOTICE
!node_modules/playwright-core/lib/**
.gitignore
.eslintrc.cjs
.prettierrc
tsconfig*.json
vite.config.*.ts
vitest.config.ts
**/*.map
**/*.ts
!dist/**
CONTRIBUTING.md
media/*.gif
.github/**
